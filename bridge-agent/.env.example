# Bridge Agent Environment Configuration
# Copy to .env and fill in your values

# MedLoop API URL
MEDLOOP_API_URL=https://medloop-api.onrender.com

# Bridge shared key (32-byte hex). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Server stores SHA-256 of this in clients.bridge_key_hash. NEVER reuse across tenants.
MEDLOOP_API_KEY=

# Numeric tenant id this bridge belongs to (optional, speeds up server lookup)
MEDLOOP_CLIENT_ID=

# Bridge HTTP port (devices POST results here)
BRIDGE_PORT=9090

# SECURITY: comma-separated CIDR/IPs allowed to connect to MLLP+HTTP listeners.
# Example: 10.0.0.0/8,192.168.1.50  (empty = allow all - LAN-only assumption)
BRIDGE_ALLOWED_IPS=

# Default device UUID (from MedLoop device registration)
DEFAULT_DEVICE_ID=

# Folder to watch for exported result files (optional)
# Supports: .json, .hl7, .csv, .txt
WATCH_FOLDER=

# ──────────────────────────────────────────
# HL7 v2.x MLLP Settings
# ──────────────────────────────────────────

# Enable/disable HL7 MLLP listener
HL7_ENABLED=true

# TCP port for HL7 MLLP connections (standard: 2575)
HL7_PORT=2575

# Device UUID to tag HL7 results with (falls back to DEFAULT_DEVICE_ID)
HL7_DEVICE_ID=

# ──────────────────────────────────────────
# Serial Port (RS-232) Settings
# ──────────────────────────────────────────

# Serial port path (empty = disabled)
# Windows: COM1, COM3, etc.
# Linux: /dev/ttyUSB0, /dev/ttyS0
SERIAL_PORT=

# Baud rate (common: 9600, 19200, 38400, 115200)
SERIAL_BAUD=9600

# Serial data mode: 'hl7' (HL7 messages) or 'raw' (CSV/delimited)
SERIAL_MODE=hl7

# Device UUID for serial results (falls back to DEFAULT_DEVICE_ID)
SERIAL_DEVICE_ID=
